    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "fast-xml-parser": "^5.7.3",
    "lucide-vue-next": "^0.562.0",
    "nanoid": "^5.1.11",
    "pinia-plugin-persistedstate": "^4.3.0",
    "potrace": "^2.1.8",
    "prismjs": "1.30.0",
