    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.4.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.4.23",
    "eslint": "^10.0.3",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
