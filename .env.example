# =====================================================
# Application
# =====================================================
# 외부에서 접근할 앱 URL (SSR / SEO / sitemap 기준)
API_BASE_URL=https://example.com

# 데이터 암호화 키 (32자 이상 랜덤 문자열 권장)
CRYPTO_SECRET_KEY=your-secret-key-here

# =====================================================
# Ollama (AI 메타 제안)
# =====================================================
# 로컬 dev (pnpm dev) 기준 — 호스트에서 직접 Ollama 에 붙음.
#   ⚠️ host.docker.internal 은 컨테이너 전용 hostname 이라 호스트에서 사용 불가.
#       그래서 .env 에는 127.0.0.1 을 두고, 컨테이너 안에서는 docker-compose.yml
#       의 environment 가 자동으로 host.docker.internal 로 덮어씀.
#
#   대안: 호스트 LAN IP 직접 지정 (예: http://192.168.0.63:11434)
#   대안: Ollama 도 컨테이너로 운영 시 http://ollama:11434 (compose 에 service 추가 필요)
OLLAMA_URL=http://127.0.0.1:11434

# 사용할 모델 이름. 사전에 `ollama pull <name>` 으로 받혀있어야 함.
OLLAMA_MODEL=qwen3.5:9b

# 추론 타임아웃 (ms). 초과 시 silent fallback — 앱은 멈추지 않고
# AI 메타 제안만 비활성화됨.
OLLAMA_TIMEOUT_MS=30000